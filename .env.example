# ── Server ────────────────────────────────────────────────────────────────
PORT=3000

# ── Monitoring ────────────────────────────────────────────────────────────
# Gap in milliseconds between the end of one scan and the start of the next.
# A scan itself takes ~1-3s, so detection latency ≈ CHECK_INTERVAL + 3s.
# Minimum enforced: 2000. Very low values increase the risk of bot-blocking.
CHECK_INTERVAL=10000

# The BookMyShow "buy tickets" page to watch.
TARGET_URL=https://in.bookmyshow.com/movies/bengaluru/jana-nayagan/buytickets/ET00430817/20260723

# ── WhatsApp ──────────────────────────────────────────────────────────────
# Recipients, comma-separated. Country code + number, digits only
# (no +, spaces or dashes). A group id like "123456789@g.us" also works.
# Example: WHATSAPP_NUMBERS=919876543210,918765432109
WHATSAPP_NUMBERS=91XXXXXXXXXX

# ── Playwright ────────────────────────────────────────────────────────────
# true = run the scraping browser headless. Set to false to watch it work.
HEADLESS=true

# ── Optional (sensible defaults are applied when omitted) ─────────────────
# Display name used in alerts. Falls back to the name scraped from the page.
MOVIE_NAME=Jana Nayagan

# Retries per scan before the scan is marked failed.
MAX_RETRIES=3

# Base delay (ms) for exponential backoff between retries: base * 2^attempt.
RETRY_BASE_DELAY=5000

# Playwright navigation timeout in milliseconds.
NAV_TIMEOUT=60000

# Winston log level: error | warn | info | debug
LOG_LEVEL=info
