  "description": "Monitors a BookMyShow booking page and sends WhatsApp alerts when new theatres, shows or booking slots appear",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "postinstall": "npx playwright install chromium"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "bookmyshow",
    "monitor",
    "playwright",
    "whatsapp",
    "scraper"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vishwavinoth/bookmyshow-monitor.git"
  },
  "homepage": "https://github.com/vishwavinoth/bookmyshow-monitor#readme",
  "bugs": {
    "url": "https://github.com/vishwavinoth/bookmyshow-monitor/issues"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "playwright": "^1.48.0",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.26.0",
    "winston": "^3.14.2"
  }
}
